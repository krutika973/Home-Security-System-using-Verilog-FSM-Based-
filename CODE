//Code
module home_security_system (
    input wire clk,
    input wire reset,
    input wire motion_sensor,
    input wire door_sensor,
    input wire window_sensor,
    input wire [3:0] keypad,
    input wire enter,
    output reg alarm,
    output reg armed
);

// Define the states for the FSM
typedef enum logic [1:0] {
    DISARMED = 2'b00,
    ARMED = 2'b01,
    ALARM_TRIGGERED = 2'b10
} state_t;

state_t current_state, next_state;

// Define the correct keypad code
parameter [3:0] correct_code = 4'b1010;

// State transition and output logic
always @(posedge clk or posedge reset) begin
    if (reset) begin
        current_state <= DISARMED;
        alarm <= 1'b0;
        armed <= 1'b0;
    end else begin
        current_state <= next_state;
    end
end

// Next state logic
always @(*) begin
    next_state = current_state;
    case (current_state)
        DISARMED: begin
            alarm = 1'b0;
            armed = 1'b0;
            if (enter && keypad == correct_code) begin
                next_state = ARMED;
            end
        end
        ARMED: begin
            alarm = 1'b0;
            armed = 1'b1;
            if (motion_sensor || door_sensor || window_sensor) begin
                next_state = ALARM_TRIGGERED;
            end
            if (enter && keypad == correct_code) begin
                next_state = DISARMED;
            end
        end
        ALARM_TRIGGERED: begin
            alarm = 1'b1;
            armed = 1'b1;
            if (enter && keypad == correct_code) begin
                next_state = DISARMED;
            end
        end
        default: begin
            next_state = DISARMED;
        end
    endcase
end

endmodule
