module home_security_system_tb;

    // Inputs
    reg clk;
    reg reset;
    reg motion_sensor;
    reg door_sensor;
    reg window_sensor;
    reg [3:0] keypad;
    reg enter;

    // Outputs
    wire alarm;
    wire armed;

    // Instantiate the Unit Under Test (UUT)
    home_security_system uut (
        .clk(clk),
        .reset(reset),
        .motion_sensor(motion_sensor),
        .door_sensor(door_sensor),
        .window_sensor(window_sensor),
        .keypad(keypad),
        .enter(enter),
        .alarm(alarm),
        .armed(armed)
    );

    // Clock generation
    always #5 clk = ~clk; // 10ns clock period

    initial begin
        // Initialize Inputs
        clk = 0;
        reset = 0;
        motion_sensor = 0;
        door_sensor = 0;
        window_sensor = 0;
        keypad = 4'b0000;
        enter = 0;

        // Apply reset
        #10 reset = 1;
        #10 reset = 0;

        // Test Case 1: Arm the system with correct code
        #10 keypad = 4'b1010; enter = 1;
        #10 enter = 0;

        // Verify armed state
        #20 if (armed !== 1) $display("Test Case 1 Failed");

        // Test Case 2: Trigger the alarm with motion sensor
        #10 motion_sensor = 1;
        #10 if (alarm !== 1) $display("Test Case 2 Failed");
        #10 motion_sensor = 0;

        // Test Case 3: Disarm the system with correct code
        #10 keypad = 4'b1010; enter = 1;
        #10 enter = 0;

        // Verify disarmed state
        #20 if (armed !== 0 || alarm !== 0) $display("Test Case 3 Failed");

        // Test Case 4: Arm the system again
        #10 keypad = 4'b1010; enter = 1;
        #10 enter = 0;

        // Test Case 5: Trigger the alarm with door sensor
        #10 door_sensor = 1;
        #10 if (alarm !== 1) $display("Test Case 5 Failed");
        #10 door_sensor = 0;

        // Test Case 6: Disarm the system again
        #10 keypad = 4'b1010; enter = 1;
        #10 enter = 0;

        // Verify disarmed state
        #20 if (armed !== 0 || alarm !== 0) $display("Test Case 6 Failed");

        // Test Case 7: Arm the system once more
        #10 keypad = 4'b1010; enter = 1;
        #10 enter = 0;

        // Test Case 8: Trigger the alarm with window sensor
        #10 window_sensor = 1;
        #10 if (alarm !== 1) $display("Test Case 8 Failed");
        #10 window_sensor = 0;

        // Test Case 9: Disarm the system once more
        #10 keypad = 4'b1010; enter = 1;
        #10 enter = 0;

        // Verify disarmed state
        #20 if (armed !== 0 || alarm !== 0) $display("Test Case 9 Failed");

        // Finish simulation
        #10 $stop;
    end
  initial begin
    $dumpfile("dump.vcd");
    $dumpvars(1);
  end

endmodule





